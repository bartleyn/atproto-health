{
  "name": "atproto-health",
  "version": "1.0.0",
  "description": "ATProto ecosystem health dashboard",
  "scripts": {
    "postinstall": "xattr -w com.apple.fileprovider.ignore#P 1 node_modules 2>/dev/null || true && xattr -w com.apple.fileprovider.ignore#P 1 *.db *.db-shm *.db-wal 2>/dev/null || true",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "collect": "npx tsx src/lib/collectors/run.ts",
    "collect:geo": "npx tsx src/lib/collectors/run.ts --geo",
    "collect:users": "npx tsx src/lib/collectors/run.ts --users",
    "sample": "npx tsx src/lib/collectors/run-jetstream.ts",
    "collect:ecosystem": "npx tsx src/lib/collectors/run-ecosystem.ts",
    "collect:plc": "npx tsx src/lib/collectors/run-plc.ts",
    "collect:plc:creations": "npx tsx src/lib/collectors/run-plc-creations.ts",
    "aggregate:plc": "npx tsx src/lib/collectors/run-aggregate-plc.ts",
    "aggregate:active-plc": "npx tsx src/lib/collectors/aggregate-active-plc.ts",
    "collect:skywatch": "npx tsx src/lib/collectors/skywatch-labels.ts",
    "collect:activity": "npx tsx src/lib/collectors/jetstream-activity.ts",
    "scan:pds-status": "npx tsx src/lib/collectors/scan-pds-status.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "d3-sankey": "^0.12.3",
    "d3-shape": "^3.2.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-sankey": "^0.12.5",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-simple-maps": "^3.0.6",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.6.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
